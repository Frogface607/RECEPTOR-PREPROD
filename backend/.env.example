# =============================================================
# RECEPTOR CO-PILOT — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/receptor_pro
# Alternative: MONGO_URL (either one works)
DB_NAME=receptor_pro

# ---- Security ----
JWT_SECRET_KEY=generate-a-strong-random-secret-here
ADMIN_SECRET=your-admin-secret-for-endpoints
ENCRYPTION_KEY=your-encryption-key-for-iiko-credentials

# ---- AI / LLM ----
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...
# Optional: Tavily for web search in Deep Research
TAVILY_API_KEY=tvly-...

# ---- CORS ----
# Comma-separated list of allowed origins (use * for development only)
CORS_ORIGINS=https://your-frontend-domain.com

# ---- Environment ----
ENVIRONMENT=development
# Set to "production" to enable security validations at startup
