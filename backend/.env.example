# =============================================================
# RECEPTOR — AI-платформа управления рестораном
# receptorai.pro
# =============================================================

# ---- MongoDB ----
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/receptor_pro
DB_NAME=receptor_pro

# ---- Security ----
JWT_SECRET_KEY=generate-a-strong-random-secret-here
ADMIN_SECRET=your-admin-secret-for-endpoints
ENCRYPTION_KEY=your-encryption-key-for-iiko-credentials

# ---- AI / LLM ----
# OpenRouter (primary) — все модели через один API
OPENROUTER_API_KEY=sk-or-...
# OpenAI (optional fallback)
OPENAI_API_KEY=sk-...
# Tavily (optional — web search in Deep Research)
TAVILY_API_KEY=tvly-...

# ---- Payments (YooKassa) ----
YOKASSA_SHOP_ID=your-shop-id
YOKASSA_SECRET_KEY=your-secret-key

# ---- CORS ----
CORS_ORIGINS=https://receptorai.pro

# ---- Environment ----
ENVIRONMENT=production
