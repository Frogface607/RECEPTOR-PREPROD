# Receptor v2 — env vars
# Copy to .env.local and fill in. Never commit .env.local.

# ===== Phase 0: mock-first mode =====
# When true, lib/iiko/client.ts reads from src/lib/mock/ instead of real iiko.
# Default for dev/preview until iiko keys arrive (after 31 May 2026).
USE_MOCK_IIKO=true

# ===== Supabase (Phase 3) =====
# Project: receptor-prod (repurposed from Doomsday)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Anthropic (Phase 4) =====
ANTHROPIC_API_KEY=

# ===== OpenRouter (fallback, Phase 4) =====
OPENROUTER_API_KEY=

# ===== Credentials encryption =====
# 32 bytes hex (generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# ===== Optional, later phases =====
# PERPLEXITY_API_KEY=    # Phase 4 — Deep Research
# YOOKASSA_SHOP_ID=      # Phase 5 — Billing
# YOOKASSA_SECRET_KEY=   # Phase 5 — Billing
