# Receptor v2 — env vars
# Copy to .env.local and fill in. Never commit .env.local.

# ===== iiko data source =====
# true  → deterministic Edison demo fixtures (default; safe for any deploy)
# false → real iiko Cloud, requires an apiLogin below
# Leave true for the Михно demo. See docs/REAL_CONNECT.md to go live.
USE_MOCK_IIKO=true

# Real iiko Cloud apiLogin (only used when USE_MOCK_IIKO=false).
# Venue-specific key wins over the generic one. For venue id "edison-demo"
# the prefix is EDISON:
EDISON_IIKO_API_LOGIN=
# Generic fallback for any venue without its own key:
IIKO_API_LOGIN=

# ===== Anthropic (powers AI chat + the 27 tools) =====
# When set to a real sk-ant-... key, /api/tools/run and the chat call Claude.
# Without it, both fall back to deterministic mock output.
ANTHROPIC_API_KEY=

# ===== OpenRouter (optional fallback) =====
OPENROUTER_API_KEY=

# ===== Supabase (Phase 3 — auth, not yet wired) =====
# Project: receptor-prod (repurposed from Doomsday)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Credentials encryption =====
# 32 bytes hex (generate via: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY=

# ===== Optional, later phases =====
# PERPLEXITY_API_KEY=    # Phase 4 — Deep Research
# YOOKASSA_SHOP_ID=      # Phase 5 — Billing
# YOOKASSA_SECRET_KEY=   # Phase 5 — Billing
