# Receptor v2 env vars
# Copy to .env.local and fill in. Never commit .env.local.

# ===== iiko data source =====
# true  -> deterministic sandbox fixtures (default; safe for local/dev)
# false -> real iiko Cloud, requires an apiLogin below
USE_MOCK_IIKO=true

# Real iiko Cloud apiLogin fallback for venues without saved credentials.
IIKO_API_LOGIN=

# ===== AI providers (powers chat + the 27 tools) =====
# OpenAI is preferred when OPENAI_API_KEY is present. Anthropic remains a
# compatible fallback. Without either, tools fall back to deterministic output.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ANTHROPIC_API_KEY=

# ===== OpenRouter (optional fallback) =====
OPENROUTER_API_KEY=

# ===== Supabase =====
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Credentials encryption =====
# 32 bytes hex:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ===== Developer access =====
# Enables a protected sandbox login on /auth when email magic links are not
# convenient. Do not expose the access key publicly.
RECEPTOR_DEV_MODE=false
RECEPTOR_DEV_EMAIL=
RECEPTOR_DEV_ACCESS_KEY=

# ===== Daily Brief delivery =====
# Telegram bot token from @BotFather and target chat/user/channel id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ===== Optional, later phases =====
# PERPLEXITY_API_KEY=
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
