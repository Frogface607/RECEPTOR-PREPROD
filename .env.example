# ============================================
# RECEPTOR PRO - Environment Variables
# ============================================
# 
# Этот файл содержит все необходимые переменные окружения
# для запуска Receptor PRO в production
#
# ВАЖНО: Скопируй эти переменные в Emergent Dashboard
# перед деплоем на receptorai.pro!
#
# ============================================

# ==========================================
# 🚨 КРИТИЧЕСКИ ВАЖНЫЕ ПЕРЕМЕННЫЕ
# ==========================================
# БЕЗ ЭТИХ ПЕРЕМЕННЫХ ПОЛУЧИШЬ 403 ОШИБКУ!

# V2 Feature Flag - включает генерацию техкарт V2
FEATURE_TECHCARDS_V2=true

# LLM для V2 - включает использование GPT для генерации
TECHCARDS_V2_USE_LLM=true

# OpenAI API Key - для генерации контента через GPT-4o/GPT-4o-mini
OPENAI_API_KEY=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

# MongoDB - база данных для хранения техкарт
MONGO_URL=mongodb://localhost:27017/receptor_pro
DB_NAME=receptor_pro

# ==========================================
# 🔧 ДОПОЛНИТЕЛЬНЫЕ ПЕРЕМЕННЫЕ
# ==========================================

# Application Configuration
APP_URL=https://receptorai.pro
DEBUG=false

